{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=ShvaTransactionDb;User Id=sa;Password=YourStrong@Pass123;TrustServerCertificate=True;MultipleActiveResultSets=true;"
  },
  "DatabaseConfig": {
    "SchemaName": "shva"
  },
  "BankPolicy": {
    "DefaultOpeningTime": "09:00:00",
    "DefaultClosingTime": "18:00:00",
    "IsWeekendClosed": true,
    "SupportGlobalTimeZones": true
  },
  "PagingConfig": {
    "DefaultPageSize": 10,
    "MaxPageSize": 50,
    "EnablePagination": true,
    "DefaultPageNumber": 1
  },
  "CorsConfig": {
    "PolicyName": "AllowReactApp",
    "AllowedOrigins": [ "http://localhost:5173" ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ]
  },
  "Jwt": {
    "Key": "YourVerySuperSecretKeyThatIsAtLeast32CharsLong!",
    "Issuer": "ShvaSimulator",
    "Audience": "ShvaSimulatorUsers",
    "DurationInMinutes": 120
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}